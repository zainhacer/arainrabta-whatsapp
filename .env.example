# ================================================================
# ArainRabta WhatsApp Service — Environment Variables
# Copy this to .env and fill in your values
# ================================================================

# Service security key — generate a random string, keep it secret
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WA_SERVICE_SECRET=your-random-secret-key-here

# Supabase connection (for reading notification queue)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# WhatsApp session name (any string)
WA_SESSION_NAME=arainrabta

# Port for the HTTP server
PORT=3000

# Admin WhatsApp number for status alerts (with country code, no + or spaces)
# e.g. 923001234567
ADMIN_PHONE=923001234567
